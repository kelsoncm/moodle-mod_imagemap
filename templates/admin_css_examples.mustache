{{!
    Template for CSS examples admin page
    Displays CSS examples organized by type (active, inactive, acthover, inahover)
    in a tabbed interface with cards for each example.

    Expected context data structure:
    {
        "heading": string,
        "addbutton": html,
        "exportbutton": html,
        "importbutton": html,
        "types": [
            {
                "type": "active",
                "tabid": "tab-active",
                "paneid": "active-pane",
                "label": "CSS Ativo",
                "has_examples": boolean,
                "active": boolean,
                "examples": [
                    {
                        "name": string,
                        "sortorder": int,
                        "css_text": string,
                        "editurl": moodle_url,
                        "deleteurl": moodle_url
                    }
                ]
            }
        ]
    }

    @package    mod_imagemap
    @copyright  2026 Kelson C. M.
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}

{{{heading}}}

<div class="mb-3">
    {{{addbutton}}}
    {{{exportbutton}}}
    {{{importbutton}}}
</div>

<div class="css-tabs-container mb-4">
    {{#types}}
    <input type="radio" name="css-tab" id="{{tabid}}" {{#active}}checked{{/active}}>
    {{/types}}

    <div class="css-tabs">
        {{#types}}
        <label for="{{tabid}}" class="css-tab">{{{label}}}</label>
        {{/types}}
    </div>

    <div class="css-tab-content">
        {{#types}}
        <div class="css-tab-pane" id="{{paneid}}">
            {{#has_examples}}
            <div class="row">
                {{#examples}}
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="card-title mb-0">{{{name}}}</h5>
                            <small class="text-muted">{{#str}}order{{/str}}: {{sortorder}}</small>
                        </div>
                        <div class="card-body">
                            <div class="css-preview mb-2 text-center">
                                <canvas class="css-preview-canvas" data-css="{{css_text}}" width="190" height="80"></canvas>
                            </div>
                            <p class="card-text"><code>{{css_text}}</code></p>
                        </div>
                        <div class="card-footer">
                            <a href="{{{editurl}}}" class="btn btn-sm btn-outline-primary me-2">{{#str}}edit{{/str}}</a>
                            <a href="{{{deleteurl}}}" class="btn btn-sm btn-outline-danger" onclick="return confirm('{{#str}}confirmdeleteexample, imagemap{{/str}}');">{{#str}}delete{{/str}}</a>
                        </div>
                    </div>
                </div>
                {{/examples}}
            </div>
            {{/has_examples}}
            {{^has_examples}}
            <p>{{#str}}noexamples, imagemap{{/str}}</p>
            {{/has_examples}}
        </div>
        {{/types}}
    </div>
</div>
